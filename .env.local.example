# MongoDB connection string
# Get yours free at https://cloud.mongodb.com
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/toyota-dealership?retryWrites=true&w=majority

# Admin secret — used to protect admin API routes and dashboard login
# Change this to a long, random string before deploying
ADMIN_SECRET=change-me-to-a-long-random-secret-string

# App URL (used for absolute URL construction if needed)
NEXT_PUBLIC_APP_URL=http://localhost:3000
